# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/dbname

# Environment
NODE_ENV=production
PORT=3000

# Supabase Authentication (Crucial for PRODUCTION stability)
# 1. Login to Supabase Dashboard
# 2. Go to Project Settings -> API
# 3. SUPABASE_JWT_SECRET corresponds to the "JWT Secret" field.
SUPABASE_JWT_SECRET=your_jwt_secret_here

# 4. (Optional) SUPABASE_JWT_PUBLIC_KEY is used for asymmetric verification.
# SUPABASE_JWT_PUBLIC_KEY=your_public_key_here
