# 🏛️ Alberta Citizen Incident Reporting Portal - Gitignore

# [ CORE ]
node_modules/
dist/
dist-server/
.angular/
.nest/
*.tsbuildinfo
.DS_Store
Thumbs.db

# [ ENVIRONMENT ]
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.sample
!.env.example

# [ TESTING & COVERAGE ]
coverage/
cypress/videos/
cypress/screenshots/
.nyc_output/
*.lcov

# [ LOGS ]
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# [ IDE / EDITORS ]
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
.idea/
*.swp
*.swo
.project
.classpath
.settings/

# [ INFRA & DEPLOYMENT ]
.railway/
railway.json

# [ ASSISTANT & KNOWLEDGE ]
.gemini/
.antigravity/
.agents/
knowledge/
brain/
*.md.tmp
scripts/tmp/
