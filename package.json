{
  "name": "alberta-incident-portal",
  "version": "1.0.0",
  "description": "High-fidelity municipal command interface for non-emergency incident triage and forensic reporting.",
  "author": "Municipal Public Safety Division",
  "license": "Private",
  "private": true,
  "homepage": "https://alberta-incident.ssowemimo.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/femisowems/alberta-incident-report.git"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run start --workspace=client",
    "dev:server": "npm run start:dev --workspace=server",
    "build:all": "npm run build --workspaces",
    "build:client": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "lint:all": "npm run lint --workspaces",
    "lint:client": "npm run lint --workspace=client",
    "lint:server": "npm run lint --workspace=server",
    "test:all": "npm run test --workspaces",
    "test:client": "npm run test --workspace=client",
    "test:server": "npm run test --workspace=server",
    "clean": "rm -rf client/dist server/dist node_modules .angular .nest",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
